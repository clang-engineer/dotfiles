# SSH keys (machine-specific, never commit — any name, not just id_*)
id_*
github_actions
github_actions.pub

# Known hosts (machine-specific)
known_hosts
known_hosts.old

# Other sensitive files
*.pem
*.key
authorized_keys

# Real host configs are symlinked in from the private `secrets` repo.
# Keep only the generic, shareable ones in this public repo.
config.d/*
!config.d/00-global
!config.d/template.example
