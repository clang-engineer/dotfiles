# 상황에 따라 선택
brew "autojump"          # zoxide로 대체 가능
brew "git-lfs"           # 대용량 파일 다루는 프로젝트 없으면 불필요
brew "libpq"             # PostgreSQL 안 쓰면 불필요
brew "pyenv"             # uv로 대체 가능
brew "pyenv-virtualenv"  # uv로 대체 가능
brew "rbenv"             # Ruby 개발 안 하면 불필요
brew "uv"                # pyenv 쓰면 중복될 수 있음
brew "wget"              # curl이 기본 내장
