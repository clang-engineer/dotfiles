# Core tools
brew "git"
brew "neovim"
brew "tmux"
brew "sesh"            # tmux 스마트 세션 매니저 — fzf+zoxide 피커로 디렉토리/git repo 세션 점프 (tmux prefix+T)
brew "starship"        # Cross-shell prompt (replaces powerlevel10k); init in .zshrc
brew "fzf"              # Fuzzy finder (Ctrl+R history, Ctrl+T files). Used by zsh/neovim telescope
brew "ripgrep"          # rg: blazing-fast text search. neovim grep backend
brew "fd"               # fd: intuitive file search (find replacement). Used by neovim file navigation
brew "lazygit"          # Git TUI client
brew "git-delta"        # delta: syntax-highlighting pager for git diff. Used by .gitconfig core.pager
brew "jq"               # CLI JSON filter/transform. Used for JSON parsing in scripts
brew "bat"              # cat replacement (syntax highlight, line numbers). Used by fzf preview
brew "tree"             # Print directory tree
brew "eza"              # ls replacement (color, git status, icons)
brew "gh"               # GitHub CLI (PR/issue/Actions)
brew "tldr"             # Condensed man pages — just the key examples

# zsh plugins (sourced directly in .zshrc — no framework)
brew "zsh-autosuggestions"       # fish-style suggestions from history
brew "zsh-syntax-highlighting"   # fish-style command syntax highlighting

# Runtime version management — mise owns node/ruby/java (see ~/.config/mise/config.toml)
brew "mise"
brew "jdtls"             # Eclipse JDT language server (nvim LSP; not a runtime)

# Optional, depending on your needs
brew "zoxide"            # z: smart directory jump (autojump replacement)
brew "git-lfs"           # Not needed if you have no projects with large files
brew "libpq"             # Includes the psql CLI. Not needed if you don't use PostgreSQL
brew "uv"                # Fast Python package/venv manager — owns Python (mise handles node/ruby/java)
brew "wget"              # File downloader. curl is built in by default
