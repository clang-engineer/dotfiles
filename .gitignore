# tags
tags
.DS_Store

# SSH keys / sensitive — machine-specific, never commit (any name, repo-wide)
id_*
github_actions
github_actions.pub
known_hosts*
*.pem
*.key
authorized_keys
# SSH host configs overlaid from the private `secrets` repo (only 00-global tracked)
chezmoi/private_dot_ssh/config.d/[1-9]*
packages/Brewfile.lock.json

*.swp

# secrets (tokens, credentials)
.secrets
.secrets.ps1

# claude code: ignore everything, allow only tracked configs
claude/*
!claude/CLAUDE.md
!claude/README.md
!claude/settings.template.json
!claude/keybindings.json
!claude/statusline.sh
!claude/check-env.sh
!claude/link-commands.sh
!claude/commands/

# local tool settings
.claude/settings.local.json
.serena/
