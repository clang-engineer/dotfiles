# tags
tags
.DS_Store

# SSH keys / sensitive — machine-specific, never commit (any name, repo-wide)
id_*
github_actions
github_actions.pub
known_hosts*
*.pem
*.key
authorized_keys
# SSH host configs overlaid from the private `secrets` repo (only 00-global tracked)
chezmoi/private_dot_ssh/private_config.d/[1-9]*
packages/Brewfile.lock.json

*.swp

# secrets (tokens, credentials)
.secrets
.secrets.ps1

# nvim DB connections are private (overlaid from the secrets repo) — only db/init.lua is tracked.
# Any subdirectory here (connections/, backups, etc.) must never be committed.
nvim/lazy/lua/user/db/*/

# Legacy Claude runtime source from the old whole-directory symlink layout.
# Keep ignored until every machine has run the one-time migration.
claude/*

# local tool settings
.claude/settings.local.json
.serena/
