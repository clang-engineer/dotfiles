# tags
tags
.DS_Store

# SSH keys / sensitive — machine-specific, never commit (any name, repo-wide)
id_*
github_actions
github_actions.pub
known_hosts*
*.pem
*.key
authorized_keys
# SSH host configs overlaid from the private `secrets` repo (only 00-global tracked)
chezmoi/private_dot_ssh/private_config.d/[1-9]*
packages/Brewfile.lock.json

*.swp

# secrets (tokens, credentials)
.secrets
.secrets.ps1

# nvim DB connections are private (overlaid from the secrets repo) — only db/init.lua is tracked.
# Any subdirectory here (connections/, backups, etc.) must never be committed.
nvim/lazy/lua/user/db/*/

# Claude Code source: ignore everything, allow only the public native config.
# Runtime data now lives in ~/.claude; this remains a defense against accidentally
# adding generated settings or private overlays during migration.
claude/*
!claude/README.md
!claude/keybindings.json
!claude/link-commands.sh
!claude/statusline.sh

# local tool settings
.claude/settings.local.json
.serena/
