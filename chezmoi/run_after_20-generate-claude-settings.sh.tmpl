#!/usr/bin/env bash
# Generate ~/.claude/settings.json from the template, injecting machine-local
# additionalDirectories. ~/.claude is a symlink to the repo, so this writes into
# repo/claude/settings.json (gitignored) — same as bootstrap's generate_settings.
# Machine paths come from ~/.secrets env; source it so this works non-interactively.
set -euo pipefail
REPO="{{ .chezmoi.sourceDir | dir }}"
[ -f "$HOME/.secrets" ] && . "$HOME/.secrets"

# Which personal dirs to expose to Claude comes from $CLAUDE_EXTRA_DIRS (a space-
# separated list set in the private secrets repo's env); empty for public clones.
dirs=()
for d in ${CLAUDE_EXTRA_DIRS:-}; do
  dirs+=("\"$d\"")
done

joined=$(printf '%s, ' "${dirs[@]}")
joined="${joined%, }"

sed "s|\"additionalDirectories\": \[\]|\"additionalDirectories\": [$joined]|" \
  "$REPO/claude/settings.template.json" > "$REPO/claude/settings.json"
printf '→ Generated claude/settings.json with directories: %s\n' "$joined"
