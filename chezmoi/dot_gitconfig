[core]
	autocrlf = input
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
# Identity ([user] name/email) is set per-machine in ~/.gitconfig.local
# (gitignored), created by chezmoi/create_dot_gitconfig.local.tmpl at init.
[include]
	path = ~/.gitconfig.local
[core]
	pager = delta
[delta]
