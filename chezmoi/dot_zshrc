# Auto-start tmux (only when not already inside tmux, excluding IDE built-in terminals)
if command -v tmux &>/dev/null && [[ -z "$TMUX" ]] && [[ "$TERMINAL_EMULATOR" != "JetBrains-JediTerm" ]]; then
  tmux attach || tmux new -s default
fi

# Locale
export LANG=ko_KR.UTF-8

# Load secrets (tokens, credentials) from a local-only file
[ -f ~/.secrets ] && source ~/.secrets

# Cache the brew prefix (brew --prefix is slow, so call it only once)
if command -v brew >/dev/null 2>&1; then
  BREW_PREFIX="$(brew --prefix)"
  # Homebrew completions (must be on fpath before compinit)
  fpath=("$BREW_PREFIX/share/zsh/site-functions" $fpath)
fi

# Completion system (git, etc.) — was provided by oh-my-zsh
autoload -Uz compinit && compinit
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'  # case-insensitive matching
zstyle ':completion:*' menu select                      # arrow-key menu selection
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}" # color matches like ls

# Command typo correction: 'gti status' → "correct 'gti' to 'git' [nyae]?" prompt
setopt CORRECT

# Project directory vars come from the private secrets repo, loaded via ~/.secrets

# Preferred editor for local and remote sessions
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='nvim'
fi

# Modern CLI aliases
if command -v bat &>/dev/null; then alias cat="bat"; fi
if command -v eza &>/dev/null; then alias ls="eza"; fi

# c++ alias
alias g++="g++ -std=c++17"
alias clang++="clang++ -std=c++17"

# rbenv
if command -v rbenv &>/dev/null; then
  eval "$(rbenv init - zsh)"
fi

# nvm
export NVM_DIR=~/.nvm
if [[ -n "$BREW_PREFIX" && -s "$BREW_PREFIX/opt/nvm/nvm.sh" ]]; then
  source "$BREW_PREFIX/opt/nvm/nvm.sh"
fi

# jenv
if command -v jenv &>/dev/null; then
  export PATH="$HOME/.jenv/bin:$PATH"
  eval "$(jenv init -)"
fi

# pyenv
if command -v pyenv &>/dev/null; then
  eval "$(pyenv init --path)"
  eval "$(pyenv init -)"
  eval "$(pyenv virtualenv-init -)"
fi

# fzf (Ctrl+T file select, Ctrl+R history, Alt+C directory jump)
if command -v fzf &>/dev/null; then
  source <(fzf --zsh)
fi

# zoxide (autojump replacement, z/zi commands)
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
fi

# starship (cross-shell prompt; replaced the old powerlevel10k theme)
if command -v starship &>/dev/null; then
  eval "$(starship init zsh)"
fi

# zsh plugins (installed via brew; replaced oh-my-zsh's plugin loader).
# syntax-highlighting must be sourced last, after all other zle setup.
if [[ -n "$BREW_PREFIX" ]]; then
  source "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
  source "$BREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi

