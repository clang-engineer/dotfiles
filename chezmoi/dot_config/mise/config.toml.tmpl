# mise — declarative runtime versions (replaced rbenv/jenv/pyenv/nvm).
# `mise install` reads this; shell profiles activate it on PATH.
# Python is intentionally absent — uv owns Python here.
[tools]
node = "24"
{{ if ne .chezmoi.os "windows" -}}
ruby = "3.4.2"
{{ end -}}
# First entry is the default on PATH; the rest are switchable via `mise use java@temurin-17`.
java = ["temurin-21", "temurin-17", "temurin-11"]
