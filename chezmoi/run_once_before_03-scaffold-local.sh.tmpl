#!/usr/bin/env bash
# Scaffold machine-local files from templates if missing — never overwrites.
# (Interactive customization still available via scripts/setup-secrets.sh.)
set -euo pipefail
REPO="{{ .chezmoi.sourceDir | dir }}"

scaffold() {  # <example> <target> <mode>
  [ -f "$2" ] && return 0
  cp "$1" "$2" && chmod "$3" "$2"
  printf '→ Created %s from template — fill in your values\n' "$2"
}

scaffold "$REPO/scripts/.secrets.example"         "$HOME/.secrets"         600
scaffold "$REPO/scripts/.gitconfig.local.example" "$HOME/.gitconfig.local" 644
# ~/.pgpass is not scaffolded here — the private secrets repo owns it and
# symlinks it into place via run_after_30-secrets-overlay.sh → secrets/setup.sh.
