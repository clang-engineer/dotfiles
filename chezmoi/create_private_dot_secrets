# ~/.secrets — local-only credentials, never committed. chezmoi creates this once
# (0600, never overwritten). Add exports as you need them, e.g.:
# export GITHUB_TOKEN="..."       # gh CLI + cloning the private secrets repo
# export ANTHROPIC_API_KEY="..."
#
# If you have secrets-repo access, its `setup.sh` appends a managed block below that
# sources your machine paths and any synced secrets. Leave that block to the script.
