#!/usr/bin/env bash
set -euo pipefail

claude_home="$HOME/.claude"
expected_source="{{ .chezmoi.sourceDir | dir }}/claude"

[[ -L "$claude_home" ]] || exit 0

link_target="$(readlink "$claude_home")"
if [[ "$link_target" != "$expected_source" ]]; then
  printf 'Refusing to replace unexpected ~/.claude symlink: %s\n' "$link_target" >&2
  exit 1
fi

migration_dir="$HOME/.claude.migrating"
if [[ -e "$migration_dir" ]]; then
  printf 'Refusing to overwrite existing migration directory: %s\n' "$migration_dir" >&2
  exit 1
fi
mkdir "$migration_dir"

shopt -s dotglob nullglob
if [[ -d "$expected_source" ]]; then
  for source_path in "$expected_source"/*; do
    mv "$source_path" "$migration_dir/"
  done
  rmdir "$expected_source"
fi

rm "$claude_home"
mv "$migration_dir" "$claude_home"
printf 'Migrated Claude runtime data into %s\n' "$claude_home"
