# ~/.secrets — local-only credentials (DO NOT commit actual values)
# Copy this file to ~/.secrets and fill in your values:
#   cp ~/.secrets.example ~/.secrets
#   chmod 600 ~/.secrets
#
# This file is sourced by .bashrc and .zshrc automatically.
# For PowerShell, use ~/.secrets.ps1 instead.

export GITHUB_ACTOR=""
export GITHUB_TOKEN=""

# Workspace root (adjust per machine)
export WORKSPACE_DIR="$HOME/workspace"
export VAULT_DIR="$WORKSPACE_DIR/vault"
export DOTFILES_DIR="$WORKSPACE_DIR/dotfiles"
export BLOG_DIR="$WORKSPACE_DIR/your-blog.github.io"
export DEVKIT_DIR="$WORKSPACE_DIR/devkit"

# Add more secrets as needed:
# export AWS_ACCESS_KEY_ID=""
# export AWS_SECRET_ACCESS_KEY=""
# export OPENAI_API_KEY=""
# export ANTHROPIC_API_KEY=""
