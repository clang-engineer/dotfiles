# PostgreSQL password file format reference (public dotfiles)
# The real ~/.pgpass is owned and overlaid by the private secrets repo:
#   secrets/postgres/pgpass → secrets/setup.sh symlinks it + chmod 600.
# Without secrets access, create it by hand from this file:
#   cp scripts/.pgpass.example ~/.pgpass && chmod 600 ~/.pgpass
#
# Format: hostname:port:database:username:password
# - wildcard *: matches any value
# - escape special characters (:, \) with \
# - permission 600 required

# Examples:
# db.example.com:5432:mydb:myuser:CHANGE_ME
# localhost:15432:*:postgres:CHANGE_ME
