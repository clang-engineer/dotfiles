# ~/.pgpass — PostgreSQL password file (DO NOT commit actual values)
#
# Format: hostname:port:database:username:password
# - Wildcards: 별표(*) 사용 가능 (예: *:5432:*:myuser:mypw)
# - Permissions: chmod 600 ~/.pgpass (Unix 필수, 그렇지 않으면 psql이 무시함)
# - Windows 위치: %APPDATA%\postgresql\pgpass.conf
#
# Setup:
#   ./scripts/setup-pgpass.sh
# 또는 수동:
#   cp scripts/.pgpass.example ~/.pgpass
#   chmod 600 ~/.pgpass
#
# vim-dadbod-ui 연동: nvim/lazy/lua/config/options/dbui.lua 의 vim.g.dbs URL에는
# user/password를 넣지 않고, psql이 이 파일에서 자동으로 읽도록 둔다.

localhost:5432:mydb:<USER>:<PASSWORD>
REDACTED_IP:5432:mydb:<USER>:<PASSWORD>
